{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/event/:id", "destination": "/api/serve-html" },
    { "source": "/donate", "destination": "/api/serve-html" },
    { "source": "/org/:slug/event/:id", "destination": "/api/serve-html" },
    { "source": "/org/:slug/donate", "destination": "/api/serve-html" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
